[local]
localhost ansible_connection=local

[myserver]
192.0.2.10 ansible_user=myuser

[boxes]
box1 ansible_host=192.0.2.21
box2 ansible_host=192.0.2.22
box3 ansible_host=192.0.2.23

[boxes:vars]
ansible_user=myuser

[vps]
123.123.123.123 ansible_user=myuser ansible_port=2222 ansible_ssh_private_key_file=~/.ssh/vps

[vps:vars]
use_email_relay=true
