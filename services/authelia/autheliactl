#!/bin/bash
set -eo pipefail

export VAULT_ADDR="http://127.0.0.1:8200"
export VAULT_TOKEN=$(sudo age -d -i /root/.config/sops/age/keys.txt /root/.vault-credentials.age) || { echo "Error: failed to decrypt Vault token" >&2; exit 1; }
vault token lookup > /dev/null 2>&1 || { echo "Error: Vault is sealed or not authenticated" >&2; exit 1; }

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VARS_FILE="$SCRIPT_DIR/../../vars.yml"

export BASE_DOMAIN=$(grep '^domain:' "$VARS_FILE" | awk '{print $2}')
export DOMAIN="auth.${BASE_DOMAIN}"

# Fetch Authelia secrets from Vault
AUTHELIA_SECRETS=$(vault kv get -format=json secret/authelia | jq -r '.data.data')
export AUTHELIA_JWT_SECRET=$(echo "$AUTHELIA_SECRETS" | jq -r '.jwt_secret')
export AUTHELIA_SESSION_SECRET=$(echo "$AUTHELIA_SECRETS" | jq -r '.session_secret')
export AUTHELIA_STORAGE_ENCRYPTION_KEY=$(echo "$AUTHELIA_SECRETS" | jq -r '.storage_encryption_key')

# Fetch SMTP from Vault
SMTP_SECRETS=$(vault kv get -format=json secret/smtp | jq -r '.data.data')
export SMTP_ENDPOINT=$(echo "$SMTP_SECRETS" | jq -r '.smtp_endpoint')
export SMTP_USERNAME=$(echo "$SMTP_SECRETS" | jq -r '.smtp_username')
export SMTP_PASSWORD=$(echo "$SMTP_SECRETS" | jq -r '.smtp_password')

# Generate config from template
envsubst < "$SCRIPT_DIR/configuration.yml.template" | sudo tee /opt/authelia/configuration.yml > /dev/null

exec docker compose "$@"
